---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../lib/siteConfig";
import { getBasePath } from "../lib/paths";
const basePath = getBasePath();
---

<BaseLayout title="About • Maco Coaching" description="About Maco Strategy Coaching.">
  <section class="hero">
    <h1>About</h1>
    <p>
      Maco Strategy Coaching is structured, practical coaching for professionals who want clarity and momentum without
      hype. If you’re navigating a transition, stepping into leadership, or simply ready for a more intentional next
      chapter, we’ll build a plan you can execute.
    </p>
    <div class="cta-row">
      <a class="button primary" href={`${basePath}/`}>Back home</a>
      <a class="button accent" href={`${basePath}/#book`}>Free 20-min discovery call</a>
    </div>
  </section>

  <section class="section" aria-label="Coach bio">
    <h2>Stephen Macomber</h2>
    <div class="bio">
      <img class="headshot" src={`${basePath}/headshot.png`} alt="Headshot of Stephen Macomber" width="320" height="320" />
      <div>
        <p class="lede">
          I bring nearly two decades of experience leading large, complex organizations in high-stakes environments —
          including directing a <strong>190+ person technical department</strong> and overseeing a <strong>$65M technology portfolio</strong>.
          My background includes building and leading enterprise cybersecurity and cloud organizations, implementing identity
          and access management at scale, and guiding leaders through operational complexity with calm, structured decision-making.
        </p>
        <p class="lede">
          I combine that experience with rigorous business and analytics training: an <strong>MBA (University of Florida)</strong>
          and a <strong>Master of Science in Business Intelligence &amp; Analytics</strong>, plus advanced certifications across
          cybersecurity governance, cloud, IT service management, and program delivery. Today I advise founders and leadership
          teams through <strong>Maco Strategy LLC</strong> and co-founded <strong>Tailwind Behavior Services</strong>.
        </p>
        <p class="lede">
          On the coaching side, I’ve completed <strong>40 hours of coaching education</strong> through the
          <strong>Flatter Leadership Academy</strong> and I’m actively working toward the <strong>ICF ACC credential</strong>.
          That matters because it anchors our work in the International Coaching Federation’s competency framework and ethics —
          emphasizing clear agreements, powerful questions, active listening, client-led goals, and measurable progress.
        </p>
        <div class="bio-links">
          <a class="button primary" href="https://www.linkedin.com/in/stephen-macomber/" rel="me noopener" target="_blank">
            LinkedIn profile
          </a>
          <a class="button" href={`mailto:${siteConfig.contactEmail}`}>Email: {siteConfig.contactEmail}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
